{
  "name": "neosql-mcp",
  "version": "0.0.1",
  "description": "Local stdio MCP server that connects MCP hosts to NeoSQL Desktop on macOS and Windows.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unvus/neosql-mcp.git"
  },
  "homepage": "https://github.com/unvus/neosql-mcp#readme",
  "bugs": {
    "url": "https://github.com/unvus/neosql-mcp/issues"
  },
  "bin": {
    "neosql-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "neosql",
    "stdio",
    "database",
    "electron"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --exclude '**/*.spawn.test.ts'",
    "test:integration": "npm run build && vitest run spawn.test",
    "check:desktop-installation": "npm run build && node dist/check-desktop-installation.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
